## Director bindings

<!-- Director reads these on boot. Prompts for any missing entry and writes the answer back. -->

event-bus: jsonl              # jsonl (.arc/events.jsonl) | db | <skill-name>
task-delegation: native       # native (harness agent tool) | arc-agents | <skill-name>
workspace: worktree           # worktree | treehouse | <skill-name>
on-task-verified: merge       # merge | draft-pr | <skill-name>
todo-list: native             # native | arc-agents | <skill-name>
feedback-sink: jsonl          # jsonl (.arc/feedback.jsonl) | <api-url> | <skill-name>
planning-target: prd-file     # prd-file | arc-agents-ledger | kanban | <skill-name>
memory: .arc/director         # .arc/director (in-repo, default) | ~/vault/agents/director | <path>

model:
  director: fable > opus > sonnet  # director's own tick (self-spawned --afk cron invocation only);
                                    # first tier the harness actually has wins
  director-effort: max
  worker: sonnet                   # every task-delegation dispatch (/task, adversarial-review, qa-sweep, ...)
  worker-effort: max
  env:
    DISABLE_INTERLEAVED_THINKING: "true"   # applied to both director and worker invocations

scheduler:
  mode: cron                  # cron (self-installed backstop) | arc-agents | <skill-name>
  backstop-hours: 12          # idle-backstop tick cadence; lower = more frequent wake, higher token floor

budget:
  weekly: 500k                # tokens/week for THIS repo; resets Monday 00:00 UTC
  bypass:
    - critical-failure        # qa.failed with dimension: critical-failure
    - security                # qa.failed with dimension: security
  # over budget restricts dispatch to bypass-only, never a hard halt.
  # if task-delegation: arc-agents, this can shell to that repo's own
  # bin/director-governor.ts (sentinel dir + --weekly-budget) for the
  # threshold/pause/kill mechanics instead of reimplementing them here.

## Worker agents

<!-- Declare what worker types exist and how to spawn them.
     Director reads task.type and looks up the matching entry here.

     Completion contract every worker must honor when it emits task.completed:
       - evidence:[{path,description}]           (required — no evidence, re-queued)
       - wires-to:<live-path>  OR  inert:true    (required — is this capability
         reachable from a live entry path, or does it ship inert? inert:true makes
         the director auto-open an activation candidate so wiring can't dangle)
     Any worker MAY emit task.discovered {parent, gap, evidence} to nominate a
     follow-up gap it uniquely learned (an orphaned wiring, a latent bug in
     untouched code). It lands as an unverified candidate — the director validates
     against source before delegating; nomination never mints work directly. -->

# tdd-implementation: DISABLE_INTERLEAVED_THINKING=true claude --model sonnet --effort max -p "$(cat .arc/specs/{slice}.md)" --skill tdd
# adversarial-review: DISABLE_INTERLEAVED_THINKING=true claude --model sonnet --effort max -p "review this diff for correctness" --skill code-review
# qa-sweep:           DISABLE_INTERLEAVED_THINKING=true claude --model sonnet --effort max -p "$(cat .arc/specs/{slice}.md)" --skill qa

